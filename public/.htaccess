# ----------------------------------------------------------------------
# DissertlyPro cPanel production configuration
# ----------------------------------------------------------------------

# Disable directory browsing
Options -Indexes

# ----------------------------------------------------------------------
# Canonical host + HTTPS
# ----------------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301,NE]

  # Force non-www
  RewriteCond %{HTTP_HOST} ^www\.dissertlypro\.com$ [NC]
  RewriteRule ^ https://dissertlypro.com%{REQUEST_URI} [L,R=301,NE]

  # Legacy URL redirects
  RewriteRule ^citing-ai/?$ /citing-ai-guide [R=301,L]

  # Remove trailing slash for non-directories
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} .+/$
  RewriteRule ^(.+)/$ /$1 [R=301,L]

  # SPA fallback for React Router
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

# ----------------------------------------------------------------------
# Compression (Brotli + Gzip)
# ----------------------------------------------------------------------
<IfModule mod_brotli.c>
  BrotliCompressionQuality 5
  AddOutputFilterByType BROTLI_COMPRESS text/plain text/html text/xml text/css application/javascript application/json application/xml image/svg+xml
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css application/javascript application/json application/xml image/svg+xml
</IfModule>

# ----------------------------------------------------------------------
# Caching strategy
# ----------------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML should refresh quickly
  ExpiresByType text/html "access plus 5 minutes"

  # App assets (Vite hashed files)
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"

  # Static media
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"

  # SEO/Discovery files should refresh often
  ExpiresByType text/plain "access plus 1 day"
  ExpiresByType application/xml "access plus 1 day"
  ExpiresByType text/xml "access plus 1 day"
  ExpiresByType application/json "access plus 1 day"
</IfModule>

<IfModule mod_headers.c>
  # Immutable cache for build artifacts
  <FilesMatch "\.(?:css|js|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # Discovery + HTML freshness
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=300, must-revalidate"
  </FilesMatch>

  <FilesMatch "\.(?:xml|txt|json)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>

  # Security hardening
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
  Header always set X-Frame-Options "SAMEORIGIN"

</IfModule>

# ----------------------------------------------------------------------
# 404 + UTF-8 handling
# ----------------------------------------------------------------------
AddDefaultCharset UTF-8
